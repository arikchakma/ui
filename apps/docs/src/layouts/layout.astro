---
import '../styles/global.css';

const site = 'https://cromia.arikko.dev';

const {
  title = 'Cromia - Headless Color Picker Primitives for React',
  description = 'Headless, composable color picker primitives for React. Unstyled, accessible, and fully customizable.',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, site).href;
const ogImage = new URL('/og.png', site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#ffffff" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Arik Chakma" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content="cromia – headless color picker primitives for React" />
    <meta property="og:site_name" content="Cromia" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@imarikchakma" />
    <meta name="twitter:creator" content="@imarikchakma" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="cromia – headless color picker primitives for React" />
  </head>
  <body>
    <slot />
  </body>
</html>
