---
import { createHighlighter, type Highlighter } from 'shiki';
import Copy from '../icons/copy.astro';
import Check from '../icons/check.astro';

interface Props {
  code: string;
  lang?: string;
  filename?: string;
}

let _highlighter: Highlighter;
async function getHighlighter() {
  if (!_highlighter) {
    _highlighter = await createHighlighter({
      themes: ['github-light-default'],
      langs: ['tsx', 'bash'],
    });
  }
  return _highlighter;
}

const { code, lang = 'tsx', filename } = Astro.props;

const highlighter = await getHighlighter();

const lineCount = code.trim().split('\n').length;
const gutterWidth = String(lineCount).length;

const html = highlighter.codeToHtml(code.trim(), {
  lang,
  theme: 'github-light-default',
});
---

<div class="code-block group relative overflow-hidden border border-gray-200" style={`--gutter-width: ${gutterWidth}ch;`}>
  {filename && (
    <div class="flex items-center border-b border-gray-200 px-4 py-2">
      <span class="font-mono text-[12px] text-gray-400">{filename}</span>
    </div>
  )}

  <div class="relative">
    <div class="code-content overflow-x-auto" set:html={html} />
    <button
      class="copy-btn absolute right-2 top-1.5 flex size-7 items-center justify-center border border-gray-200 bg-white text-gray-400 opacity-0 transition-all hover:text-black group-hover:opacity-100"
      aria-label="Copy code"
    >
      <Copy class="copy-icon size-3.5" />
      <Check class="check-icon hidden size-3.5" />
    </button>
  </div>
</div>

<style is:global>
  .code-block .shiki {
    margin: 0;
    padding: 0.75rem;
    background-color: #ffffff !important;
    font-size: 12.5px;
    line-height: 1.6;
    counter-reset: line;
  }

  .code-block .shiki code {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace;
  }

  .code-block .shiki code .line::before {
    counter-increment: line;
    content: counter(line);
    display: inline-block;
    width: var(--gutter-width, 2ch);
    margin-right: 1.25rem;
    text-align: right;
    color: #d1d5db;
    user-select: none;
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const block = btn.closest('.code-block');
      const code = block?.querySelector('.shiki code');
      if (!code) {
        return;
      }

      await navigator.clipboard.writeText(code.textContent ?? '');

      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement;

      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');

      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
      }, 2000);
    });
  });
</script>
