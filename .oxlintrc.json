{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import"],
  "rules": {
    "typescript/consistent-type-imports": "error",
    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
    "curly": ["error", "all"]
  },
  "ignorePatterns": [
    "coverage/",
    "coverage-merged/",
    "**/dist/",
    "**/node_modules/",
    "**/.vercel/"
  ]
}
