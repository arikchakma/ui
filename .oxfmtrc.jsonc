{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortImports": {},
  "experimentalSortPackageJson": {
    "sortScripts": true,
  },
  "ignorePatterns": ["coverage/", "coverage-merged/", "dist/", "node_modules/"],
}
