---
import Layout from '../layouts/layout.astro';
import { ColorPickerExamples } from '../components/color-picker-demo';
import CodeBlock from '../components/code-block.astro';
import GitHub from '../icons/github.astro';

const installCode = `npm install cromia`;

const basicUsage = `import { ColorPicker } from 'cromia';
import { useState } from 'react';

function Picker() {
  const [color, setColor] = useState('#3B82F6');

  return (
    <ColorPicker.Root color={color} onColorChange={setColor}>
      <ColorPicker.Area className="relative h-48 w-full">
        <ColorPicker.AreaBackground />
        <ColorPicker.AreaThumb />
      </ColorPicker.Area>

      <ColorPicker.ChannelSlider channel="hue">
        <ColorPicker.ChannelSliderTrack />
        <ColorPicker.ChannelSliderThumb />
      </ColorPicker.ChannelSlider>

      <ColorPicker.Input channel="hex" />
    </ColorPicker.Root>
  );
}`;

const swatchesUsage = `const swatches = ['#E44444', '#3B82F6', '#22C55E'];

<ColorPicker.Root color={color} onColorChange={setColor}>
  <ColorPicker.SwatchGroup>
    {swatches.map((c) => (
      <ColorPicker.Swatch
        key={c}
        value={c}
        selected={color === c}
        onSelect={setColor}
      />
    ))}
  </ColorPicker.SwatchGroup>
</ColorPicker.Root>`;

const channelsUsage = `const channels = ['hue', 'saturation', 'brightness', 'alpha'];

<ColorPicker.Root color={color} onColorChange={setColor}>
  {channels.map((ch) => (
    <div key={ch}>
      <ColorPicker.Input channel={ch} />
      <ColorPicker.ChannelSlider channel={ch}>
        <ColorPicker.ChannelSliderTrack />
        <ColorPicker.ChannelSliderThumb />
      </ColorPicker.ChannelSlider>
    </div>
  ))}
</ColorPicker.Root>`;
---

<Layout>
  <div class="flex min-h-screen flex-col">
    <header>
      <div class="h-[1.5px] w-full" style="background: linear-gradient(to right, #f87171, #fb923c, #facc15, #4ade80, #22d3ee, #60a5fa, #a78bfa);"></div>
      <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4 sm:px-8">
        <a href="/" class="font-serif text-lg font-light tracking-tight text-gray-800 no-underline hover:no-underline">cromia</a>
        <div class="flex items-center gap-4">
          <span class="rounded-full border border-gray-200 bg-gray-50 px-2.5 py-0.5 font-mono text-[11px] text-gray-400">v0.0.1</span>
          <a href="https://www.npmjs.com/package/cromia" target="_blank" rel="noopener noreferrer" class="text-gray-400 transition-colors hover:text-gray-600 no-underline hover:no-underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm19.2 19.2H12v-9.6H7.2v9.6H4.8V4.8h14.4v14.4z"/></svg>
          </a>
          <a href="https://github.com/arikchakma/cromia" target="_blank" rel="noopener noreferrer" class="text-gray-400 transition-colors hover:text-gray-600 no-underline hover:no-underline">
            <GitHub class="size-[18px]" />
          </a>
        </div>
      </nav>
    </header>
    <div class="flex-1 px-6 py-16 sm:px-8 max-w-4xl mx-auto w-full">
      <ColorPickerExamples client:load />

      <div class="spacer-divider mt-24 mb-10"></div>
      <section class="mx-auto max-w-xl">
        <header class="mb-10">
          <p class="font-mono text-[10px] tracking-widest text-gray-300">USAGE</p>
          <h2 class="mt-1 font-semibold tracking-[-0.01em] text-gray-800">Getting started</h2>
          <p class="mt-1 text-sm text-balance leading-relaxed text-gray-400">
            Install the package and compose your own picker from headless primitives. Every component is unstyled — bring your own classes.
          </p>
        </header>

        <div class="space-y-10">
          <div>
            <div class="mb-3">
              <p class="font-medium text-gray-700">Install</p>
              <p class="mt-1 text-sm text-balance leading-relaxed text-gray-400">Add cromia to your project. Works with any React 18+ or 19+ setup.</p>
            </div>
            <CodeBlock code={installCode} lang="bash" />
          </div>

          <div>
            <div class="mb-3">
              <p class="font-medium text-gray-700">Basic picker</p>
              <p class="mt-1 text-sm text-balance leading-relaxed text-gray-400">Compose a minimal picker with an area selector, hue slider, and hex input. Every piece is a separate component you can style and arrange however you like.</p>
            </div>
            <CodeBlock code={basicUsage} lang="tsx" filename="color-picker.tsx" />
          </div>

          <div>
            <div class="mb-3">
              <p class="font-medium text-gray-700">Color swatches</p>
              <p class="mt-1 text-sm text-balance leading-relaxed text-gray-400">Add preset color swatches so users can quickly pick from a curated palette. The selected state is managed automatically.</p>
            </div>
            <CodeBlock code={swatchesUsage} lang="tsx" filename="color-picker.tsx" />
          </div>

          <div>
            <div class="mb-3">
              <p class="font-medium text-gray-700">Channel sliders</p>
              <p class="mt-1 text-sm text-balance leading-relaxed text-gray-400">Expose individual hue, saturation, brightness, and alpha channels as editable sliders with matching text inputs for precise control.</p>
            </div>
            <CodeBlock code={channelsUsage} lang="tsx" filename="color-picker.tsx" />
          </div>
        </div>
      </section>
    </div>
    <footer>
      <div class="mx-auto max-w-4xl px-6 py-4 sm:px-8">
        <div class="spacer-divider"></div>
      </div>
      <div class="mx-auto flex max-w-4xl px-6 py-4 sm:px-8 items-center justify-between text-xs text-gray-400">
        <p>Built with ❤️ by <a href="https://x.com/imarikchakma" target="_blank" rel="noopener noreferrer" class="text-gray-500 underline underline-offset-2 hover:text-gray-700">Arik Chakma</a></p>
        <a href="https://github.com/arikchakma/cromia" target="_blank" rel="noopener noreferrer" class="text-gray-500 underline underline-offset-2 hover:text-gray-700">GitHub</a>
      </div>
    </footer>
  </div>
</Layout>

