---
import Layout from '../layouts/layout.astro';
import { ColorPickerExamples } from '../components/color-picker-demo';
import GitHub from '../icons/github.astro';
---

<Layout>
  <div class="flex min-h-screen flex-col">
    <header>
      <div class="h-[1.5px] w-full" style="background: linear-gradient(to right, #f87171, #fb923c, #facc15, #4ade80, #22d3ee, #60a5fa, #a78bfa);"></div>
      <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4 sm:px-8">
        <a href="/" class="font-serif text-lg font-light tracking-tight text-stone-800 no-underline hover:no-underline">cromia</a>
        <div class="flex items-center gap-4">
          <span class="rounded-full border border-stone-200 bg-stone-50 px-2.5 py-0.5 font-mono text-[11px] text-stone-400">v0.0.1</span>
          <a href="https://www.npmjs.com/package/cromia" target="_blank" rel="noopener noreferrer" class="text-stone-400 transition-colors hover:text-stone-600 no-underline hover:no-underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm19.2 19.2H12v-9.6H7.2v9.6H4.8V4.8h14.4v14.4z"/></svg>
          </a>
          <a href="https://github.com/arikchakma/cromia" target="_blank" rel="noopener noreferrer" class="text-stone-400 transition-colors hover:text-stone-600 no-underline hover:no-underline">
            <GitHub class="size-[18px]" />
          </a>
        </div>
      </nav>
    </header>
    <div class="flex-1 px-6 py-16 sm:px-8 max-w-4xl mx-auto w-full">
      <ColorPickerExamples client:load />
    </div>
    <footer>
      <div class="mx-auto max-w-4xl px-6 py-4 sm:px-8">
        <div class="spacer-divider"></div>
      </div>
      <div class="mx-auto flex max-w-4xl px-6 py-4 sm:px-8 items-center justify-between text-xs text-stone-400">
        <p>Built with ❤️ by <a href="https://x.com/imarikchakma" target="_blank" rel="noopener noreferrer" class="text-stone-500 underline underline-offset-2 hover:text-stone-700">Arik Chakma</a></p>
        <a href="https://github.com/arikchakma/cromia" target="_blank" rel="noopener noreferrer" class="text-stone-500 underline underline-offset-2 hover:text-stone-700">GitHub</a>
      </div>
    </footer>
  </div>
</Layout>

