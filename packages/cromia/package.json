{
  "name": "cromia",
  "version": "0.0.1",
  "description": "Headless, composable color picker primitives for React. Unstyled, accessible, and fully customizable.",
  "keywords": [
    "accessible",
    "color",
    "color-picker",
    "composable",
    "headless",
    "hsva",
    "react",
    "unstyled"
  ],
  "license": "MIT",
  "author": "Arik Chakma <arikchangma@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/arikchakma/cromia",
    "directory": "packages/cromia"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "release": "bumpp",
    "test": "vitest"
  },
  "devDependencies": {
    "@base-ui/react": "1.0.0",
    "@base-ui/utils": "0.2.3",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "bumpp": "^10.4.1",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "inlinedDependencies": {
    "@base-ui/utils": "0.2.3",
    "@base-ui/react": "1.0.0"
  }
}
